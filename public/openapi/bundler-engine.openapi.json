{
  "components": {
    "schemas": {
      "BundleWrapRequest": {
        "properties": {
          "bundle_id": {
            "title": "Bundle Id",
            "type": "string"
          },
          "child_payload_hex": {
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "title": "Child Payload Hex",
            "type": "array"
          }
        },
        "required": [
          "bundle_id",
          "child_payload_hex"
        ],
        "title": "BundleWrapRequest",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "description": "Bundler API for wrapping child semantic-layer payloads into bundle payloads that can be transported as base-layer UTXO Data.",
    "title": "EON Bundler Engine API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/bundles/wrap": {
      "post": {
        "description": "Create or inspect bundle/marketplace payloads. Bundles transport ordered data; child semantic layers still own validity.",
        "operationId": "wrap_bundle_bundles_wrap_post",
        "requestBody": {
          "content": {
            "application/json": {
              "example": {
                "bundle_id": "1111111111111111111111111111111111111111111111111111111111111111",
                "child_payload_hex": [
                  "0001000100010000000000000001"
                ]
              },
              "schema": {
                "$ref": "#/components/schemas/BundleWrapRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "bundle_id": "1111111111111111111111111111111111111111111111111111111111111111",
                  "child_count": 1,
                  "data_scalars": [
                    "0x42554e444c45"
                  ],
                  "payload_hex": "42554e444c45"
                },
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Wrap Bundle Bundles Wrap Post",
                  "type": "object"
                }
              }
            },
            "description": "Successful response."
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Wrap Bundle",
        "tags": [
          "Bundles"
        ]
      }
    },
    "/health": {
      "get": {
        "description": "Read from the health surface. Use these responses for status checks, discovery, or accepted-state reads.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "ok": true
                },
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Health Health Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful response."
          }
        },
        "summary": "Health",
        "tags": [
          "Health"
        ]
      }
    }
  },
  "servers": [
    {
      "description": "Local bundler engine",
      "url": "http://localhost:8000"
    }
  ],
  "tags": [
    {
      "description": "Liveness, readiness, and service configuration checks.",
      "name": "Health"
    },
    {
      "description": "Bundle wrapper construction from child payloads.",
      "name": "Bundles"
    }
  ]
}
