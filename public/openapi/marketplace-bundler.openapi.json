        "description": "Create or inspect bundle/marketplace payloads. Bundles transport ordered data; child semantic layers still own validity.",
        "operationId": "wrap_bundle_bundles_wrap_post",
        "requestBody": {
          "content": {
            "application/json": {
              "example": {
                "bundle_id": "1111111111111111111111111111111111111111111111111111111111111111",
                "child_payload_hex": [
                  "0001000100010000000000000001"
                ]
              },
              "schema": {
                "$ref": "#/components/schemas/BundleWrapRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "bundle_id": "1111111111111111111111111111111111111111111111111111111111111111",
                  "child_count": 1,
                  "data_scalars": [
                    "0x42554e444c45"
                  ],
                  "payload_hex": "42554e444c45"
                },
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Wrap Bundle Bundles Wrap Post",
                  "type": "object"
                }
              }
            },
            "description": "Successful response."
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
