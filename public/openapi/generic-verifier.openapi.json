{
  "components": {
    "schemas": {
      "BaseEventRequest": {
        "properties": {
          "amount": {
            "default": "0",
            "title": "Amount",
            "type": "string"
          },
          "block_hash": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Block Hash"
          },
          "cursor": {
            "title": "Cursor",
            "type": "string"
          },
          "data_scalars": {
            "items": {
              "type": "string"
            },
            "title": "Data Scalars",
            "type": "array"
          },
          "event_key": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Event Key"
          },
          "height": {
            "default": 0,
            "title": "Height",
            "type": "integer"
          },
          "network_id": {
            "default": "devnet",
            "title": "Network Id",
            "type": "string"
          },
          "output_index": {
            "default": 0,
            "title": "Output Index",
            "type": "integer"
          },
          "owner": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Owner"
          },
          "payload_hex": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Payload Hex"
          },
          "tx_hash": {
            "title": "Tx Hash",
            "type": "string"
          },
          "tx_index": {
            "default": 0,
            "title": "Tx Index",
            "type": "integer"
          },
          "utxo_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Utxo Id"
          }
        },
        "required": [
          "cursor",
          "tx_hash"
        ],
        "title": "BaseEventRequest",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "description": "Verifier API for ingesting ordered base-layer events and replaying semantic-layer rules into accepted local state. This schema is reference-first; deploy or run the verifier stack for a service URL.",
    "title": "EON Generic Verifier API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/health": {
      "get": {
        "description": "Read from the health surface. Use these responses for status checks, discovery, or accepted-state reads.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "ok": true
                },
                "schema": {
                  "additionalProperties": {
                    "type": "boolean"
                  },
                  "title": "Response Health Health Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful response."
          }
        },
        "summary": "Health",
        "tags": [
          "Health"
        ]
      }
    },
    "/verifier/events": {
      "get": {
        "description": "Read from the verifier surface. Use these responses for status checks, discovery, or accepted-state reads.",
        "operationId": "events_verifier_events_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "ok": true,
                  "status": "success"
                },
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Events Verifier Events Get",
                  "type": "object"
                }
              }
            },
            "description": "Verifier response. Prefer verifier reads for accepted semantic-layer state."
          }
        },
        "summary": "Events",
        "tags": [
          "Verifier"
        ]
      }
    },
    "/verifier/ingest-event": {
      "post": {
        "description": "Ingest or replay ordered data and read verifier-accepted semantic-layer state.",
        "operationId": "ingest_event_verifier_ingest_event_post",
        "requestBody": {
          "content": {
            "application/json": {
              "example": {
                "amount": "1",
                "block_hash": null,
                "cursor": "devnet:1:0:0",
                "data_scalars": [
                  "0x0001000100010000000000000001"
                ],
                "event_key": "devnet:1:0:0",
                "height": 1,
                "network_id": "devnet",
                "output_index": 0,
                "owner": "0xoperator",
                "payload_hex": "0001000100010000000000000001",
                "tx_hash": "0xabc123",
                "tx_index": 0,
                "utxo_id": "0xabc123:0"
              },
              "schema": {
                "$ref": "#/components/schemas/BaseEventRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "accepted": true,
                  "cursor": "devnet:1:0:0"
                },
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Ingest Event Verifier Ingest Event Post",
                  "type": "object"
                }
              }
            },
            "description": "Verifier response. Prefer verifier reads for accepted semantic-layer state."
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Ingest Event",
        "tags": [
          "Verifier"
        ]
      }
    },
    "/verifier/log": {
      "get": {
        "description": "Read from the verifier surface. Use these responses for status checks, discovery, or accepted-state reads.",
        "operationId": "log_verifier_log_get",
        "parameters": [
          {
            "example": "00010001",
            "in": "query",
            "name": "sl_id",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Sl Id"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": [
                  {
                    "cursor": "sandbox:batch:0001",
                    "status": "accepted"
                  }
                ],
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Log Verifier Log Get",
                  "type": "object"
                }
              }
            },
            "description": "Verifier response. Prefer verifier reads for accepted semantic-layer state."
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Log",
        "tags": [
          "Verifier"
        ]
      }
    },
    "/verifier/state": {
      "get": {
        "description": "Read from the verifier surface. Use these responses for status checks, discovery, or accepted-state reads.",
        "operationId": "state_verifier_state_get",
        "parameters": [
          {
            "example": "00010001",
            "in": "query",
            "name": "sl_id",
            "required": true,
            "schema": {
              "title": "Sl Id",
              "type": "string"
            }
          },
          {
            "example": "0001",
            "in": "query",
            "name": "version",
            "required": false,
            "schema": {
              "default": "0001",
              "title": "Version",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "balances": {},
                  "sl_id": "00010001",
                  "version": "0001"
                },
                "schema": {
                  "additionalProperties": true,
                  "title": "Response State Verifier State Get",
                  "type": "object"
                }
              }
            },
            "description": "Verifier response. Prefer verifier reads for accepted semantic-layer state."
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "State",
        "tags": [
          "Verifier"
        ]
      }
    }
  },
  "servers": [
    {
      "description": "Your deployed verifier service. No public hosted verifier endpoint is promoted yet.",
      "url": "https://your-verifier.example.com"
    }
  ],
  "tags": [
